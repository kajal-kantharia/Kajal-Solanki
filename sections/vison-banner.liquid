{%- comment -%}
  Vison Banner Section
  --------------------
  Full-width Swiper slider with per-slide images, text, and layout controls.
  Dynamic styles use inline attributes; static layout lives in {% style %}.
{%- endcomment -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

{%- style -%}
  .vison-gift-banner-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .shopify-section-message-{{ section.id }} .container,
  .vison-gift-banner-{{ section.id }} .container {
    max-width: {{ section.settings.container_width }};
    margin: 0 auto;
    padding: 0 15px;
    width: 100%;
  }

  .shopify-section-message-{{ section.id }} .fluid-container,
  .vison-gift-banner-{{ section.id }} .fluid-container {
    padding: 0 15px;
    width: 100%;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__swiper {
    width: 100%;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__slide {
    position: relative;
    overflow: hidden;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__media {
    position: absolute;
    inset: 0;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__picture,
  .vison-gift-banner-{{ section.id }} .vison-gift-banner__image {
    display: block;
    width: 100%;
    height: 100%;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__image {
    object-fit: cover;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__placeholder {
    width: 100%;
    height: 100%;
    background: #e8e8e8;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__container {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    width: 100%;
    box-sizing: border-box;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__content {
    width: 100%;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__heading {
    margin: 0;
    line-height: 1.05;
    font-weight: inherit;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__description {
    margin: 0;
    line-height: 1.5;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__description p {
    margin: 0 0 0.75em;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__description p:last-child {
    margin-bottom: 0;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__button {
    flex-shrink: 0;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__description .vison-description_text {
    display: none;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__description .vison-description_text_mobile {
    display: block;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn:before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 100%;
    transition: all 0.3s;
    z-index: -1;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn:hover {
    color: #000 !important;
    opacity: 0.85;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn svg,
  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn svg path,
  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn svg polygon {
    fill: #fff;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn:hover svg,
  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn:hover svg path,
  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn:hover svg polygon {
    fill: #000 !important;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn:hover:before {
    width: 100%;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__btn[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .vison-gift-banner-{{ section.id }} .vison-gift-banner__button_text {
    margin-right: 10px;
  }

  .vison-gift-banner-{{ section.id }} .swiper-button-prev,
  .vison-gift-banner-{{ section.id }} .swiper-button-next {
    color: {{ section.settings.navigation_color }};
    display: block;
  }

  .vison-gift-banner-{{ section.id }} .swiper-pagination-bullet {
    background: {{ section.settings.pagination_color }};
    opacity: 0.45;
  }

  .vison-gift-banner-{{ section.id }} .swiper-pagination-bullet-active {
    opacity: 1;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .vison-gift-banner-{{ section.id }} .vison-gift-banner__description .vison-description_text {
      display: block;
    }

    .vison-gift-banner-{{ section.id }} .vison-gift-banner__description .vison-description_text_mobile {
      display: none;
    }
  }
{%- endstyle -%}

<section
  class="vison-gift-banner vison-gift-banner-{{ section.id }} section-{{ section.id }}-padding"
  id="VisonBanner-{{ section.id }}"
>
  {%- if section.blocks.size > 0 -%}
    <div class="swiper vison-gift-banner__swiper vison-gift-banner-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- liquid
            assign slide_image = block.settings.image_desktop
            if slide_image == blank
              assign slide_image = block.settings.image_mobile
            endif

            assign image_alt = slide_image.alt | default: block.settings.heading | strip_html | escape

            assign fetch_priority = 'auto'
            if section.index == 1 and forloop.first
              assign fetch_priority = 'high'
            endif

            assign loading_mode = 'lazy'
            if section.index == 1 and forloop.first
              assign loading_mode = 'eager'
            endif

            case block.settings.content_position_desktop
              when 'top-left'
                assign desktop_justify = 'flex-start'
                assign desktop_align = 'flex-start'
              when 'top-center'
                assign desktop_justify = 'flex-start'
                assign desktop_align = 'center'
              when 'top-right'
                assign desktop_justify = 'flex-start'
                assign desktop_align = 'flex-end'
              when 'middle-left'
                assign desktop_justify = 'center'
                assign desktop_align = 'flex-start'
              when 'middle-center'
                assign desktop_justify = 'center'
                assign desktop_align = 'center'
              when 'middle-right'
                assign desktop_justify = 'center'
                assign desktop_align = 'flex-end'
              when 'bottom-left'
                assign desktop_justify = 'flex-end'
                assign desktop_align = 'flex-start'
              when 'bottom-center'
                assign desktop_justify = 'flex-end'
                assign desktop_align = 'center'
              when 'bottom-right'
                assign desktop_justify = 'flex-end'
                assign desktop_align = 'flex-end'
              else
                assign desktop_justify = 'center'
                assign desktop_align = 'center'
            endcase

            case block.settings.content_position_mobile
              when 'top-left'
                assign mobile_justify = 'flex-start'
                assign mobile_align = 'flex-start'
              when 'top-center'
                assign mobile_justify = 'flex-start'
                assign mobile_align = 'center'
              when 'top-right'
                assign mobile_justify = 'flex-start'
                assign mobile_align = 'flex-end'
              when 'middle-left'
                assign mobile_justify = 'center'
                assign mobile_align = 'flex-start'
              when 'middle-center'
                assign mobile_justify = 'center'
                assign mobile_align = 'center'
              when 'middle-right'
                assign mobile_justify = 'center'
                assign mobile_align = 'flex-end'
              when 'bottom-left'
                assign mobile_justify = 'flex-end'
                assign mobile_align = 'flex-start'
              when 'bottom-center'
                assign mobile_justify = 'flex-end'
                assign mobile_align = 'center'
              when 'bottom-right'
                assign mobile_justify = 'flex-end'
                assign mobile_align = 'flex-end'
              else
                assign mobile_justify = 'center'
                assign mobile_align = 'center'
            endcase
          -%}

          {% style %}
            .vison-banner-slide-{{ block.id }} .vison-gift-banner__container {
              min-height: {{ section.settings.height_desktop }}px;
              justify-content: {{ desktop_justify }};
              align-items: {{ desktop_align }};
            }
        
            .vison-banner-slide-{{ block.id }} .vison-gift-banner__content {
              max-width: {{ block.settings.content_width }}px;
              padding: {{ block.settings.content_padding_vertical }}px {{ block.settings.content_padding_horizontal }}px;
              text-align: {{ block.settings.text_alignment_desktop }};
            }
        
            .vison-banner-slide-{{ block.id }} .vison-gift-banner__heading {
              margin-bottom: {{ block.settings.heading_spacing }}px;
              font-size: {{ block.settings.heading_size }}px;
              color: {{ block.settings.heading_color }};
              font-family: {{ block.settings.heading_font_family.family }}, {{ block.settings.heading_font_family.fallback_families }};
            }
        
            .vison-banner-slide-{{ block.id }} .vison-gift-banner__description {
              margin-bottom: {{ block.settings.description_spacing }}px;
              font-size: {{ block.settings.description_size }}px;
              color: {{ block.settings.description_color }};
              font-family: {{ block.settings.description_font_family.family }}, {{ block.settings.description_font_family.fallback_families }};
            }

            .vison-banner-slide-{{ block.id }} .vison-gift-banner__btn {
              background-color: {{ block.settings.button_bg }};
              color: {{ block.settings.button_color }};
              border-width: {{ block.settings.button_border_width }}px;
              border-color: {{ block.settings.button_border }};
              border-radius: {{ block.settings.button_radius }}px;
              padding: {{ block.settings.button_padding_y }}px {{ block.settings.button_padding_x }}px;
              font-size: {{ block.settings.button_font_size }}px;
              font-family: {{ block.settings.button_font_family.family }}, {{ block.settings.button_font_family.fallback_families }};
            } 
            .vison-banner-slide-{{ block.id }} .vison-gift-banner__btn:before {
              border-radius: {{ block.settings.button_radius }}px;
              border-width: {{ block.settings.button_border_width }}px;
              border-color: {{ block.settings.button_border }}; 
              background-color: {{ block.settings.button_bg_hover_color }}; 
            }

            @media screen and (max-width: 749px) {
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__slide,
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__container {
                min-height: {{ section.settings.height_mobile }}px;
              }
        
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__container {
                justify-content: {{ mobile_justify }};
                align-items: {{ mobile_align }};
              }
        
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__content {
                text-align: {{ block.settings.text_alignment_mobile }};
              }
        
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__heading {
                font-size: {{ block.settings.heading_size_mobile }}px;
              }
        
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__description {
                font-size: {{ block.settings.description_size_mobile }}px;
              }
        
              .vison-banner-slide-{{ block.id }} .vison-gift-banner__btn {
                font-size: {{ block.settings.button_font_size_mobile }}px;
              }

              .vison-banner-slide-{{ block.id }} .vison-gift-banner__button {
                position: absolute;
                bottom: 10%;
                transform: translate(-50%);
                left: 50%;
              }
            }
          {% endstyle %}
          <div
            id="VisonBannerSlide-{{ block.id }}"
            class="swiper-slide vison-gift-banner__slide vison-banner-slide-{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <div class="vison-gift-banner__media">
              {%- if slide_image != blank -%}
                <picture class="vison-gift-banner__picture">
                  {%- if block.settings.image_mobile != blank -%}
                    <source
                      media="(max-width: 749px)"
                      srcset="
                        {{ block.settings.image_mobile | image_url: width: 750 }} 750w,
                        {{ block.settings.image_mobile | image_url: width: 1100 }} 1100w,
                        {{ block.settings.image_mobile | image_url: width: 1500 }} 1500w
                      "
                      sizes="100vw"
                    >
                  {%- endif -%}

                  {{
                    slide_image
                    | image_url: width: 3840
                    | image_tag:
                      class: 'vison-gift-banner__image',
                      widths: '750, 1100, 1500, 1780, 2000, 3000, 3840',
                      sizes: '100vw',
                      alt: image_alt,
                      loading: loading_mode,
                      fetchpriority: fetch_priority
                  }}
                </picture>
              {%- else -%}
                <div class="vison-gift-banner__placeholder" role="img" aria-label="{{ 'Image placeholder' | t }}"></div>
              {%- endif -%}
            </div>

            <div
              class="vison-gift-banner__container"
            >
              <div class="{% if section.settings.container %}fluid-container{% else %}container{% endif %}">
                <div
                  class="vison-gift-banner__content"
                >
                  {%- if block.settings.heading != blank -%}
                    <h2
                      class="vison-gift-banner__heading"
                    >
                      {{ block.settings.heading | newline_to_br }}
                    </h2>
                  {%- endif -%}

                  {%- if block.settings.description != blank -%}
                    <div
                      class="vison-gift-banner__description rte"
                    >
                      <span class="vison-description_text">{{ block.settings.description }}</span>
                      <span class="vison-description_text_mobile">{{ block.settings.description_mobile }}</span>
                    </div>
                  {%- endif -%}

                  {%- if block.settings.show_button and block.settings.button_label != blank -%}
                    <div class="vison-gift-banner__button">
                      <a
                        {% if block.settings.button_link == blank %}
                          role="link" aria-disabled="true"
                        {% else %}
                          href="{{ block.settings.button_link }}"
                        {% endif %}
                        class="vison-gift-banner__btn"
                        {% if block.settings.button_open_new_tab and block.settings.button_link != blank %}
                          target="_blank" rel="noopener noreferrer"
                        {% endif %}
                      >
                        <span class="vison-gift-banner__button_text">
                          {{- block.settings.button_label | escape -}}
                        </span>
                        {%- if section.settings.show_arrow -%}
                          {{- 'arrow.svg' | inline_asset_content -}}
                        {%- endif -%}
                      </a>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_pagination -%}
        <div class="swiper-pagination"></div>
      {%- endif -%}

      {%- if section.settings.show_navigation -%}
        <div class="swiper-button-prev" aria-label="{{ 'general.slider.previous' | t }}"></div>
        <div class="swiper-button-next" aria-label="{{ 'general.slider.next' | t }}"></div>
      {%- endif -%}
    </div>
  {%- else -%}
    <div
      class="vison-gift-banner__placeholder vison-gift-banner__slide"
      style="min-height: {{ section.settings.height_desktop }}px;"
    ></div>
  {%- endif -%}
</section>

{% if section.settings.message != blank %}
  {%- style -%}
    .shopify-section-message-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_message_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_message_desktop }}px;
      background-color: {{ section.settings.bg_color }};
    }
    
    .shopify-section-message-{{ section.id }} .vison-gift-message_text_mobile {
      display: none;
    }

    .shopify-section-message-{{ section.id }} .vison-gift-banner__message {
      font-size: {{ section.settings.message_size }}px;
      color: {{ section.settings.message_color }};
      font-family: {{ section.settings.message_font_family.family }}, {{ section.settings.message_font_family.fallback_families }};
      text-align: {{ section.settings.text_alignment }}; 
    }

    @media screen and (max-width: 749px) {
      .shopify-section-message-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_message_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_message_mobile }}px;
      }

      .shopify-section-message-{{ section.id }} .vison-gift-message_text_mobile {
        display: block;
      }

      .shopify-section-message-{{ section.id }} .vison-gift-message_text {
        display: none;
      }

      .shopify-section-message-{{ section.id }} .vison-gift-banner__message {
        font-size: {{ section.settings.message_size_mobile }}px;
      }
    }
  {%- endstyle -%}

  <section class="shopify-section-message-{{ section.id }}">
    <div class="{% if section.settings.container %}fluid-container{% else %}container{% endif %}">
      {%- if section.settings.message != blank -%}
        <div
          class="vison-gift-banner__message"
        >
          <span class="vison-gift-message_text">{{ section.settings.message | newline_to_br }}</span>
          <span class="vison-gift-message_text_mobile">{{ section.settings.message_mobile | newline_to_br }}</span>
        </div>
      {%- endif -%}
    </div>
  </section>
{% endif %}

{%- if section.blocks.size > 0 -%}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var swiperEl = document.querySelector('.vison-gift-banner-swiper-{{ section.id }}');
      if (!swiperEl || typeof Swiper === 'undefined') return;

      var config = {
        slidesPerView: 1,
        loop: {{ section.settings.loop }},
        speed: {{ section.settings.transition_speed }},
        effect: '{{ section.settings.effect }}',
        {% if section.settings.effect == 'fade' %}
        fadeEffect: { crossFade: true },
        {% endif %}
        {% if section.settings.autoplay %}
        autoplay: {
          delay: {{ section.settings.autoplay_speed }},
          disableOnInteraction: false,
          pauseOnMouseEnter: true
        },
        {% endif %}
        {% if section.settings.show_pagination %}
        pagination: {
          el: swiperEl.querySelector('.swiper-pagination'),
          clickable: true
        },
        {% endif %}
        {% if section.settings.show_navigation %}
        navigation: {
          nextEl: swiperEl.querySelector('.vison-gift-banner-{{ section.id }} .swiper-button-next'),
          prevEl: swiperEl.querySelector('.vison-gift-banner-{{ section.id }} .swiper-button-prev')
        }
        {% endif %}
      };

      new Swiper(swiperEl, config);
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Vison Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "checkbox",
      "id": "container",
      "label": "Full width container?",
      "default": false
    },
    {
      "type": "text",
      "id": "container_width",
      "label": "Container Width in PX",
      "default": "1280px"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Slide height (desktop)",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Slide height (mobile)",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Slider behavior"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop slides",
      "default": true
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 300,
      "max": 2000,
      "step": 100,
      "unit": "ms",
      "default": 600
    },
    {
      "type": "select",
      "id": "effect",
      "label": "Transition effect",
      "default": "slide",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "fade", "label": "Fade" }
      ]
    },
    {
      "type": "header",
      "content": "Slider arrows and pagination"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "color",
      "id": "navigation_color",
      "label": "Navigation arrow color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "color",
      "id": "pagination_color",
      "label": "Pagination dot color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "checkbox",
      "id": "show_arrow",
      "label": "Show arrow icon on button",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Message"
    },
    {
      "type": "range",
      "id": "padding_top_message_desktop",
      "label": "Desktop Padding Top",
